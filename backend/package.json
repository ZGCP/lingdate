{
  "name": "lingdate-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for lingdate app store",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "d1:create": "wrangler d1 create lingdate-db",
    "d1:execute": "wrangler d1 execute lingdate-db --file=src/schema.sql",
    "d1:seed": "node seed.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["cloudflare", "workers", "hono", "d1", "r2"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240101.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.28.0"
  },
  "dependencies": {
    "hono": "^4.0.0"
  }
}
